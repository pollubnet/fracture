@using System.Collections.ObjectModel
@using Fracture.Server.Modules.Items.Models
@using Fracture.Server.Modules.Users.Services
@rendermode InteractiveServer
@inject UserInventoryService _userInventoryService

<table class="equipmentTable">
	<tr>
		@for (var i = 0; i < 3; i++)
		{
			if (i < _userInventoryService.Equipment.Count)
			{
				<td>
					<div class="@ToCss(_userInventoryService.Equipment[i].Name)">@_userInventoryService.Equipment[i].Name</div>
				</td>
			}
			else
			{
				<td></td>
			}
		}
	</tr>

	<tr>
		@for (var i = 3; i < 6; i++)
		{
			if (i < _userInventoryService.Equipment.Count)
			{
				<td>
					<div class="@ToCss(_userInventoryService.Equipment[i].Name)">@_userInventoryService.Equipment[i].Name</div>
				</td>
			}
			else
			{
				<td></td>
			}
		}
	</tr>


</table>

@code {	

	protected override void OnInitialized()
	{
		_userInventoryService.Equipment.CollectionChanged += (sender, e) => StateHasChanged();
	}

	private string ToCss(string name)
	{
		var css = name.Split(' ').Select(x => "item-" + x.ToLower());
		return string.Join(" ", css);
	}

}
